# Python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# Local caches — regenerated on demand (downloaded data, trained VQC weights),
# not versioned. Removing these keeps the repo small and reproducible from code.
data_cache/
models_cache/

# Scratch / logs
scratch/
*.log

# Per-cell checkpoints (resume state; regenerated)
results/checkpoints/
# Kaggle/Colab run downloads: only the .ipynb itself is tracked under notebooks/,
# never the exported run directories (results dumps, zips, duplicated source).
notebooks/*/
